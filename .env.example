# Salin file ini menjadi ".env" lalu isi dengan data Firebase project kamu.
# Cara ambil nilai ini: Firebase Console > Project Settings > General > Your apps > SDK setup and configuration.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Nomor WhatsApp tujuan pesanan, format internasional TANPA tanda "+" dan TANPA spasi.
# Contoh nomor 0812-3456-7890 menjadi 6281234567890
VITE_WHATSAPP_NUMBER=6285243243638
